# PostgreSQL
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=your_database_name
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# HyperSync (Envio)
HYPERSYNC_BEARER_TOKEN=

# Merkl API (no auth required for public endpoints)
MERKL_URL=https://app.merkl.xyz/opportunities/celo/CLAMM/0xYourPoolAddress

# Pool config (used by Airflow DAGs and make ingest)
POOL_CHAIN=celo
POOL_ADDRESS=0xYourPoolAddress

# dbt
DBT_PROFILES_DIR=./dbt
